{
  "manifest_version": 3,
  "name": "GitHub Pilot",
  "version": "1.0.0",
  "description": "Transform your GitHub profile into a recruiter-ready professional profile using AI.",
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"],
      "css": ["styles/content.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*",
    "http://localhost:8000/*",
    "https://*.onrender.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["sidebar.html", "assets/*", "styles/*"],
      "matches": ["https://github.com/*"]
    }
  ]
}
